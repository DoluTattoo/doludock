root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.ps1]
end_of_line = crlf

[*.{cmake,txt}]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

# The license is a verbatim third-party document: never reformat it.
[LICENSE]
trim_trailing_whitespace = false
insert_final_newline = false
